#!/bin/sh
echo "*** starting dbus-lynx-distributor ***"
exec 2>&1
cd /data/dbus-lynx-distributor

# Install/upgrade pinned dependencies. The check-then-install pattern
# keeps the daemon-startup near-instant when nothing changes, while
# still picking up an updated requirements.txt.
REQ_HASH_FILE=/data/dbus-lynx-distributor/.requirements.installed
REQ_HASH_NOW=$(md5sum requirements.txt | cut -d' ' -f1)
REQ_HASH_PREV=$(cat "$REQ_HASH_FILE" 2>/dev/null || echo "")

if [ "$REQ_HASH_NOW" != "$REQ_HASH_PREV" ]; then
    echo "requirements.txt changed (or never installed) — running pip install"
    if python3 -m pip install -r requirements.txt; then
        echo "$REQ_HASH_NOW" > "$REQ_HASH_FILE"
    else
        echo "WARNING: pip install failed — starting with whatever is currently available"
    fi
fi

exec python3 -m dbus_lynx_distributor -c config.ini -v
